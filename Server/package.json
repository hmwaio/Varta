{
  "name": "server",
  "version": "1.0.0",
  "description": "Varta backend",
  "license": "ISC",
  "author": "hmwaio",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "run": "tsc-watch --onSuccess \"node dist/index.js\"",
    "start:dev": "tsx watch --env-file=.env.development src/index.ts",
    "start:prod": "node --env-file=.env.production dist/index.js",
    "docker:dev": "docker compose up -d",
    "docker:prod": "docker compose -f docker-compose.production.yml up -d",
    "copy:prisma": "cpx \"src/generated/**/*\" dist/generated",
    "build": "tsc -p tsconfig.build.json && cpx \"src/generated/**/*\" dist/generated",
    "start": "node dist/index.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.9",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "cpx2": "^8.0.2",
    "cross-env": "^10.1.0",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
