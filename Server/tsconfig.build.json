{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noImplicitAny": false,
    "strictNullChecks": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "skipLibCheck": true,
    "paths": {
      "@prisma/client": ["./src/generated/prisma/index.js"]
    }
  },
  "exclude": ["node_modules", "dist", "src/generated"]
}